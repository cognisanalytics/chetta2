# Copy to .env and fill in values. Do not commit .env.

# SQL Server
# - DATABASE = real database name (e.g. Chetta). "dbo" is a schema, not a database.
# - Named instance: use double backslash in .env → one backslash in SERVER (10.10.10.100\SQL2019).
SQL_SERVER_DRIVER="ODBC Driver 18 for SQL Server"
SQL_SERVER_SERVER=
SQL_SERVER_DATABASE=
SQL_SERVER_USERNAME=
SQL_SERVER_PASSWORD=
SQL_SERVER_TRUSTED_CONNECTION="no"
# If TLS/certificate errors with Driver 18: try SQL_SERVER_ENCRYPT="no" or TRUST_SERVER_CERTIFICATE="yes"
SQL_SERVER_ENCRYPT="yes"
SQL_SERVER_TRUST_SERVER_CERTIFICATE="yes"

# PostgreSQL
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_USERNAME=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=
POSTGRES_SCHEMA="public"

# Loader: progress log every N rows (0 = every batch). Default 10000.
LOAD_PROGRESS_LOG_INTERVAL=10000
